[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/RubenHayes/Hybris-API.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "Ruben-Test"]
	remote = origin
	merge = refs/heads/Ruben-Test
[branch "main"]
	remote = origin
	merge = refs/heads/main
